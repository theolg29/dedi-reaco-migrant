  panneauDialogue: {fileID: 1812315853}
  dureeTransition: 0.4
  texteDialogue: {fileID: 86247261}
  dialogues:
  - texte: "Oui, c\u2019est pour le compl\xE9ment A03, je suppose."
    duree: 3
  - texte: "Alors\u2026 on vous a envoy\xE9 pour une \xE9dition de formulaire compl\xE9mentaire,
      mais \xE9videmment ce n\u2019est jamais seulement une \xE9dition de formulaire
      compl\xE9mentaire."
    duree: 8
  - texte: "Il faut d\u2019abord v\xE9rifier que le dossier est bien rattach\xE9
      au flux de traitement correspondant \xE0 la nature de la demande, sinon le
      document sort, mais il n\u2019est pas recevable."
    duree: 6
